    "Sequence": "���<sequence>\n\n<variables>\n\t\nsample_rate = float(250000000,1e7,5e9)\nmw_freq = float(3.873000000000000e+09, 1e6, 15e9)\ndet=float(5e6, -10e6, 10e6);\nmod_depth = float(1,0,1);    % SHG 2023.02.09 0.5685\nlength_pi_pulse = float(52e-9, 2e-9, 0.5)\ntau = float(1e-6,0,1e-3)\nswitch_delay = float(1.000000000000000e-07,0,500e-9)\n%delay_wrt_1mus  = float(-0.88e-6,-0.1,0.1) % 1DExp-seq-Rabimodulated-vary-delay_wrt_1mus-2022-09-29-182523  %OLD 68e-9 calibrated by PL curve 11-08-05 13-17-48\ndelay_wrt_1mus  = float(0.2e-6,-0.1,0.1) % DLnsec LASER 1DExp-seq-Rabimodulated-vary-delay_wrt_1mus-2023-10-09-183857  \nwait_time   = float(2e-6, 0,1)\n\nmw_ampl = float(-5, -20, 15)\nampIQ = float(5,-30,17) %in dBm\nfreqIQ = float(50e6, 0,500*1e6)\n\n\n%adiabatic inversion\ndo_adiabatic_inversion = boolean(1)\nsweep_range = float(100e6, 80e6, 500e6)\nsweep_time = float(1e-6, 20e-9, 10e-6)\nfull_experiment = float(0, 0, 1)    % SHG 2023.02.09 1\n\n</variables>\n\n<shaped_pulses>\n\n</shaped_pulses>\n\n<instructions>\nlength_pi_over_2 = length_pi_pulse/2;\n\nlength_pi_over_2 = round(length_pi_over_2*sample_rate)/sample_rate; %added Sept.9 2015\n\nch_on =  [1 1 1 0 0];\n    \nPSeq = set_sample_rate(PSeq, sample_rate);\n\nPSeq = enable_channels(PSeq, 1:5,ch_on); \n\nPSeq = set_microwave(PSeq, mw_freq, mw_ampl,ampIQ,freqIQ);\n\n% Acquiring true 0 level reference \nPSeq = polarize(PSeq,sample_rate,ch_on);\nPSeq = detection(PSeq,sample_rate,delay_wrt_1mus,ch_on);\nPSeq = wait_for_awg(PSeq,sample_rate,wait_time,ch_on);\n\n% Acquire 1 level reference \nif full_experiment\nif do_adiabatic_inversion\n    PSeq = adiabatic_inversion(PSeq,sample_rate,sweep_range,sweep_time,freqIQ,ch_on,mod_depth);\n    PSeq = detection(PSeq,sample_rate,delay_wrt_1mus,ch_on);\n    PSeq = wait_for_awg(PSeq,sample_rate,wait_time,ch_on);\nend\nend\n\n%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%\n%Ramsey pulses\nPSeq = ramsey(PSeq,sample_rate,length_pi_over_2,tau,det,
    "SequenceName": "CPMG.xml",
    "Sequence": "<sequence>\r\n\r\n<variables>\r\n% general setup\r\nsample_rate = float(250000000,1e7,1.2e9)\r\n\r\n% parameters for CPMG\r\nN         = float(8,0,1e4)\r\ntau      = float(2e-6,0,1)\r\nmod_depth   = float(1,0,1);\r\nlength_pi   = float(52e-9, 2e-9, 0.5)\nphase_y    = float(90,-360,360)\r\nphase_ym   = float(270,-360,360)\r\n\r\nswitch_delay = float(1.000000000000000e-07,0,100e-9);\nwait_time   = float(2e-6, 0,1)\r\n%delay_wrt_1mus = float(68e-9,0,500e-9) %calibrated by PL curve 11-08-05 13-17-48\r\ndelay_wrt_1mus  = float(0.2e-6,-0.1,0.1) % DLnsec LASER 1DExp-seq-Rabimodulated-vary-delay_wrt_1mus-2023-10-09-183857  \r\n\r\n%adiabatic inversion\r\ndo_adiabatic_inversion = boolean(0)\r\nsweep_range = float(100e6, 80e6, 500e6)\r\nsweep_time  = float(1e-6, 100e-9, 10e-6)\r\n\r\nmw_freq     = float(3.874400000000000e+09, 1e6, 15e9)\r\nmw_ampl = float(-5, -20, 15)\nampIQ = float(5,-30,17) %in dBm\nfreqIQ      = float(50e6, 0,500*1e6)\ndetuning    = float(0,-10e6,10e6)\r\n</variables>\r\n\r\n<shaped_pulses>\r\n</shaped_pulses>\r\n\r\n<instructions>\r\nmw_freq = mw_freq + detuning;\r\nlength_pi_over_2 = length_pi/2;\r\nlength_pi = round(length_pi*sample_rate)/sample_rate;\r\nlength_pi_over_2 = round(length_pi_over_2*sample_rate)/sample_rate;\r\n%t_step=round((t_step-length_pi)*sample_rate)/sample_rate;\r\n%tau=round((tau-length_pi_over_2)*sample_rate)/sample_rate;\r\ntau=round((tau)*sample_rate)/sample_rate;\r\n    \r\nch_on = [1 1 1 0 0];\r\n\r\nPSeq = set_sample_rate(PSeq,sample_rate);\r\nPSeq = enable_channels(PSeq, 1:5,ch_on); \r\nPSeq = set_microwave(PSeq, mw_freq, mw_ampl,ampIQ,freqIQ);\r\n\r\nPSeq = polarize(PSeq,sample_rate,ch_on);\r\n\r\n% Acquiring true 0 level reference \r\nPSeq = detection(PSeq,sample_rate,delay_wrt_1mus,ch_on); \r\nPSeq = wait_for_awg(PSeq,sample_rate,wait_time,ch_on);\r\n\r\n% Acquire 1 level reference \r\n%if do_adiabatic_inversion\r\n%   PSeq = adiabatic_inversion(PSeq,sample_rate,sweep_range,sweep_time,freqIQ,ch_on,mod_depth);\r\n%   PSeq = detection(PSeq,sample_rate,delay_wrt_1mus,ch_on);\r\n%   PSeq = wait_for_awg(PSeq,sample_rate,wait_time,ch_on);\r\n%end\r\n\r\n\r\n\r\nPSeq = rabi_pulse_mod_wait_time(PSeq,sample_rate,length_pi,mod_depth,switch_delay,ch_on);\nPSeq = detection(PSeq,sample_rate,delay_wrt_1mus, ch_on);\nPSeq = wait_for_awg(PSeq,sample_rate,wait_time,ch_on);\r\n\r\n        \r\n\r\nPSeq=rabi_pulse_mod_wait_time(PSeq,sample_rate,length_pi_over_2,mod_depth,switch_delay,ch_on,phase_ym);\r\n\r\nfor hlp=1:N\r\n    PSeq=wait_for_awg(PSeq,sample_rate,tau,ch_on);\r\n    PSeq=rabi_pulse_mod_wait_time(PSeq,sample_rate,length_pi,mod_depth,switch_delay,ch_on);\r\n    PSeq=wait_for_awg(PSeq,sample_rate,tau,ch_on);\r\nend\r\n\r\nPSeq=rabi_pulse_mod_wait_time(PSeq,sample_rate,length_pi_over_2,mod_depth,switch_delay,ch_on,phase_y);\r\n\r\n\r\n% Acquire Echo and long-illumination 0 level reference\nPSeq = detection(PSeq,sample_rate,delay_wrt_1mus,ch_on);\n\r\n</instructions>\r\n\r\n</sequence>\r\n",

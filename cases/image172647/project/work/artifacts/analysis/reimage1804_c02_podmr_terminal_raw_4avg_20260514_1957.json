    "SequenceName": "Rabimodulated.xml",
    "Sequence": "���<sequence>\r\n    \r\n    <variables>\t\r\n        sample_rate = float(250000000,1e7,5e9)\r\n        mw_freq     = float(3.8751e+09, 1e9, 15e9)\r\n        detuning    = float(0,-100e6,100e6)\r\n        freqIQ      = float(50e6, 0,500e6) \n        \r\n        length_rabi_pulse   = float(52e-9, 0, 0.5)\n        length_last_wait   = float(1e-6, 0, 0.5)\r\n        mod_depth           = float(0.3,0,1)\r\n        \r\n        mw_ampl = float(-5, -20, 15)\n        ampIQ = float(5,-30,17) %in dBm\n        \r\n        %adiabatic inversion\r\n        %full_expt       = float(1,0,1);\r\n        full_expt       = float(0,0,1);\r\n        do_adiabatic_inversion = boolean(1)\r\n        \r\n        sweep_range = float(100e6, 5e6, 500e6)\r\n        sweep_time  = float(1e-6, 20e-9, 20e-6)\r\n        \r\n        %delay_wrt_1mus  = float(-0.88e-6,-0.1,0.1) % 1DExp-seq-Rabimodulated-vary-delay_wrt_1mus-2022-09-29-182523  %OLD -2.17e-6 calibrated by PL curve 11-08-05 13-17-48\r\n        delay_wrt_1mus  = float(0.2e-6,-0.1,0.1) % DLnsec LASER 1DExp-seq-Rabimodulated-vary-delay_wrt_1mus-2023-10-09-183857  \r\n        wait_time       = float(2e-6, 0,1)\r\n        switch_delay    = float(1.000000000000000e-07, -1e-6,1);\n        pumping_time = float(1e-6,0,1);\r\n        \r\n    </variables>\r\n    \r\n    <shaped_pulses>\r\n        \r\n    </shaped_pulses>\r\n    \r\n    <instructions>\r\n        mw_freq = mw_freq + detuning;\r\n        \r\n        length_rabi_pulse = round(length_rabi_pulse*sample_rate)/sample_rate;\r\n        \r\n        ch_on =  [1 1 1 0 0 0];\r\n        \r\n        PSeq = set_sample_rate(PSeq, sample_rate);\r\n        PSeq = enable_channels(PSeq, 1:6,ch_on); \r\n        PSeq = set_microwave(PSeq, mw_freq,mw_ampl,ampIQ,freqIQ);\r\n        \r\n        \r\n        % Acquiring true 0 level reference \r\n        PSeq = adj_polarize(PSeq,sample_rate,pumping_time,ch_on);\r\n        PSeq = detection(PSeq,sample_rate,delay_wrt_1mus,ch_on);\r\n        PSeq = wait_for_awg(PSeq,sample_rate,wait_time,ch_on);\r\n       \r\n        \r\n        %% Acquire 1 level reference\r\n        if abs(full_expt)>1e-12\r\n        %if do_adiabatic_inversion\r\n        %PSeq = adiabatic_inversion(PSeq,sample_rate,sweep_range,sweep_time,freqIQ,ch_on,0.4);\r\n        %else\r\n        %PSeq = rabi_pulse_mod_wait_time(PSeq,sample_rate,130e-9,1,switch_delay,ch_on);\r\n        %end\r\n        PSeq = rabi_pulse_mod_wait_time(PSeq,sample_rate,52e-9,mod_depth,switch_delay,ch_on);\r\n        %PSeq = wait_for_awg(PSeq,sample_rate,3000e-9,ch_on);\r\n        PSeq = detection(PSeq,sample_rate,delay_wrt_1mus, ch_on);\r\n        PSeq = wait_for_awg(PSeq,sample_rate,wait_time,ch_on);\r\n        end\r\n        \r\n        %PSeq = wait_for_awg(PSeq,sample_rate,500e-9,ch_on);\r\n        %PSeq = wait_for_awg(PSeq,sample_rate,length_last_wait,ch_on);\r\n        \r\n        \r\n        PSeq = rabi_pulse_mod_wait_time(PSeq,sample_rate,length_rabi_pulse,mod_depth,switch_delay,ch_on);\r\n        \r\n        \r\n        %PSeq = wait_for_awg(PSeq,sample_rate,1600e-9,ch_on);\r\n        %PSeq = wait_for_awg(PSeq,sample_rate,length_last_wait,ch_on);\r\n        \r\n        % detection\r\n        PSeq = detection(PSeq,sample_rate,delay_wrt_1mus,ch_on);\r\n        \r\n        PSeq = wait_for_awg(PSeq,sample_rate,length_last_wait,ch_on);\r\n        \r\n        %PSeq = rabi_pulse_mod_wait_time(PSeq,sample_rate,length_rabi_pulse,mod_depth,switch_delay,ch_on);\r\n        %PSeq = wait_for_awg(PSeq,sample_rate,length_last_wait,ch_on);\r\n        \r\n    </instructions>\r\n    \r\n</sequence>\r\n\r\n",

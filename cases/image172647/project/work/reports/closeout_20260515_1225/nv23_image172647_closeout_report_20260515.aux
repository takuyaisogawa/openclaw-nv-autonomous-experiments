\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Terminal 12-average CPMG N=8 review over the full 0.45--1.60 \ensuremath  {\mu \mathrm  {s}}{} scan.}}{9}{figure.6}\protected@file@percent }
